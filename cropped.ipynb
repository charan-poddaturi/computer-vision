    "import cv2\n",
    "image = cv2.imread(\"saved.webp\")\n",
    "\n",
    "if image is None:\n",
    "    print(\"Error: Could not read the image.\") \n",
    "else:\n",
    "    cropped = image[30:60, 80:120]\n",
    "    cv2.imshow(\"Cropped Image\", cropped)\n",
    "    cv2.waitKey(0)\n",
    "    cv2.destroyAllWindows()"
   ]
