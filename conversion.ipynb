   "source": [
    "import cv2\n",
    "image = cv2.imread('trial.jpeg')\n",
    "if image is None:\n",
    "    print(\"Could not read the image.\")\n",
    "else:\n",
    "    gray = cv2.cvtColor(image,cv2.COLOR_BGR2GRAY)\n",
    "\n",
    "cv2.imwrite('trial_gray.jpeg', gray)\n",
    "h, w, c = image.shape\n",
    "print(f\"Image dimensions: {w}x{h}, Channels: {c}\")"
   ]
