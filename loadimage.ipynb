    "import cv2\n",
    "\n",
    "image = cv2.imread(\"python.webp\", flags=1)\n",
    "if image is None:\n",
    "    print(\"image not found\")\n",
    "else:\n",
    "    print(\"image found\")\n",
    "    cv2.imshow(\"image\", image)\n",
    "    cv2.waitKey(0)\n",
    "    cv2.destroyAllWindows()"
   ]
